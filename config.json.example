{
    "rules": {
      "human_speaking": {
        "allowed_sources": ["gui", "stt"],
        "min_priority": 1
      },
      "ai_speaking": {
        "allowed_sources": ["tts"],
        "min_priority": 2
      },
      "tts_ready": {
        "allowed_sources": ["llm"],
        "allow_if": "True"
      },
      "user_wants_to_talk": {
        "allowed_sources": ["gui", "stt"],
        "min_priority": 1
      },
      "stt_ready": {
        "allowed_sources": ["stt", "llm"],
        "min_priority": 5
      },
      "ai_thinking": {
        "allowed_sources": ["llm"],
        "min_priority": 5
      }
    },

    "stt": {
      "whisper_server_url": "http://127.0.0.1:8081",
      "whisper_api_url": "http://127.0.0.1:8081/inference",
      "whisper_health_url": "http://127.0.0.1:8081/health",
      "sampling_rate": 16000,
      "channels": 1,
      "chunk_size": 512,
      "vad_threshold": 0.5,
      "amplitude_threshold": 0.05,
      "silence_duration": 2.0,
      "min_audio_length": 1.0
    }
  }