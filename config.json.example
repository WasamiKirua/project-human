{
    "rules": {
      "human_speaking": {
        "allowed_sources": ["gui", "stt"],
        "min_priority": 1
      },
      "ai_speaking": {
        "allowed_sources": ["tts"],
        "min_priority": 2
      },
      "tts_ready": {
        "allowed_sources": ["llm"],
        "allow_if": "True"
      },
      "user_wants_to_talk": {
        "allowed_sources": ["gui", "stt"],
        "min_priority": 1
      },
      "stt_ready": {
        "allowed_sources": ["stt", "llm"],
        "min_priority": 5
      },
      "ai_thinking": {
        "allowed_sources": ["llm"],
        "min_priority": 5
      }
    },

    "stt": {
      "whisper_server_url": "http://localhost:8081",
      "whisper_api_url": "http://localhost:8081/inference",
      "whisper_health_url": "http://localhost:8081/health",
      "sampling_rate": 16000,
      "channels": 1,
      "chunk_size": 512,
      "vad_threshold": 0.5,
      "amplitude_threshold": 0.05,
      "silence_duration": 2.0,
      "min_audio_length": 1.0,
      "max_recording_duration": 180
    },

    "api_keys": {
      "openai_api_key": "",
      "groq_api_key": ""
    },

    "memory": {
      "db_store": "shortmemdb",
      "collection_name": "ConversationMemory",
      "cluster_url": "http://localhost:8080"
    },

    "lorebook": {
      "creator": "",
      "likes": "",
      "hobbies": "",
      "mangas": "",
      "gaming": ""
    },

    "llm": {
      "llama_cpp": {
        "_comment": "Set to true if want to use",
        "enabled": "true",
        "port": "8084",
        "api_key": "not-needed",
        "model": "local-model"
      },

      "ollama": {
        "_comment": "Set to true if want to use",
        "port": "11434",
        "enabled": "false"
      }
    }
  }
